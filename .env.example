# Database (Railway Postgres or local)
DATABASE_URL="postgresql://user:password@host:port/database"

# Redis (Railway Redis or local)
REDIS_URL="redis://localhost:6379"

# Auth - use 32+ char random string for production
JWT_SECRET="your-jwt-secret"
SIWE_DOMAIN="localhost"

# Solana (from Helius Dashboard)
HELIUS_API_KEY=""
# Required for Helius webhook verification (set when creating webhook)
HELIUS_WEBHOOK_SECRET=""

# EVM (from Alchemy Dashboard)
ALCHEMY_API_KEY=""

# Cron (optional - protects /api/cron/snapshot)
CRON_SECRET=""
# Set to "true" to enqueue jobs for BullMQ worker instead of running inline
CRON_USE_QUEUE="false"

# API URL (when deployed)
NEXT_PUBLIC_API_URL="http://localhost:3000"
